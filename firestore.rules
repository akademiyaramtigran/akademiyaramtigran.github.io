rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
//  Akademîya Aram Tîgran — Firestore Security Rules  (v3: okuma izolasyonu)
//  ----------------------------------------------------------------------
//  YAZMA: rol bazlı kilitli (önceki sürümle aynı).
//  OKUMA: artık varsayılan KAPALI.
//    • Öğrenci: yalnızca KENDİ students dokümanını okur (no == e-posta öneki).
//      Diğer öğrencileri ve öğretmen listesini (PII + şifre hash'i) OKUYAMAZ.
//    • Personel (@ogretmen.aat / admin): students + teachers dahil hepsini okur.
//    • Ortak koleksiyonlar (program, duyuru, anket, mesaj, yoklama, QR…):
//      giriş yapmış herkese açık (öğrenci paneli bunları kullanır).
//    • Site (girişsiz): yalnızca news, config/applications, applicationTemplates.
//
//  Rol, Firebase Auth e-posta uzantısından anlaşılır:
//    • Öğrenci   : <no>@ogrenci.aat
//    • Öğretmen  : <no>@ogretmen.aat   (yönetici/basın/öğrenci işleri dahil)
//    • Yönetici  : admin@aramtigran.edu (yedek)
// ════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcılar ─────────────────────────────────────────────────────
    function authed()  { return request.auth != null; }
    function mail()    { return request.auth.token.email; }

    // Öğretmen + yönetici (personel)
    function isStaff() {
      return authed() && (
        mail().matches('.*@ogretmen[.]aat$') ||
        mail() == 'admin@aramtigran.edu'
      );
    }

    // Bir öğrenci/öğretmen dokümanı bu kullanıcıya mı ait? ("no" alanı = e-posta öneki)
    function ownsStudentDoc(d) { return authed() && mail() == d.no + '@ogrenci.aat'; }
    function ownsTeacherDoc(d) { return authed() && mail() == d.no + '@ogretmen.aat'; }

    // Kendi kendine "admin" olmayı engelle (isAdmin alanı true yapılamaz)
    function notGrantingAdmin() {
      return !('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false;
    }
    // "no" alanı değiştirilemesin (kimliğini başkasınınkiyle değiştiremez)
    function noUnchanged() { return request.resource.data.no == resource.data.no; }

    // Başvuru dönemi açık mı? (public create yalnızca dönem açıkken)
    function applicationsOpen() {
      return exists(/databases/$(database)/documents/config/applications)
        && get(/databases/$(database)/documents/config/applications).data.open == true;
    }

    // ── Varsayılan: HER ŞEY KAPALI ──────────────────────────────────────
    // (Aşağıdaki kurallar okuma/yazmayı koleksiyon bazında açar.)
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Öğrenciler — okuma: personel VEYA kendi kaydı ──────────────────
    // (Öğrenci istemcisi yalnızca where("no","==",kendiNo) sorgusu yapar;
    //  bu sorgu kuralla kanıtlanabilir olduğundan çalışır.)
    match /students/{id} {
      allow read:   if isStaff() || ownsStudentDoc(resource.data);
      allow create: if isStaff();
      allow update: if isStaff()
                    || (ownsStudentDoc(resource.data) && noUnchanged() && notGrantingAdmin());
      allow delete: if isStaff() || ownsStudentDoc(resource.data);
    }

    // ── Öğretmenler / Yönetici — okuma: yalnızca personel ──────────────
    match /teachers/{id} {
      allow read:   if isStaff() || ownsTeacherDoc(resource.data);
      allow create: if isStaff();
      allow update: if isStaff()
                    || (ownsTeacherDoc(resource.data) && noUnchanged() && notGrantingAdmin());
      allow delete: if isStaff();
    }

    // ── Malper nûçe (ana sayfa haberleri) — HERKESE açık okuma ─────────
    match /news/{id} {
      allow read:  if true;
      allow write: if isStaff();
    }

    // ── Serlêdan (kayıt başvuruları) — public create, sıkı sınırlı ─────
    match /applications/{id} {
      allow create: if applicationsOpen()
                    && request.resource.data.keys().hasOnly(
                      ['name','phone','dob','area','note','docs','status','dateStr','createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 80
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() <= 30
                    && (!('dob'  in request.resource.data) || request.resource.data.dob.size()  <= 20)
                    && (!('area' in request.resource.data) || request.resource.data.area.size() <= 20)
                    && (!('note' in request.resource.data) || request.resource.data.note.size() <= 500)
                    && (!('dateStr' in request.resource.data) || request.resource.data.dateStr.size() <= 20)
                    && request.resource.data.status == 'new'
                    && request.resource.data.docs is list
                    && request.resource.data.docs.size() <= 8;
      allow read, update, delete: if isStaff();
    }
    // Başvuru dönemi ayarı — site (girişsiz) okuyabilsin, yazma personel
    match /config/applications {
      allow read:  if true;
      allow write: if isStaff();
    }
    // İstenen belgeler (şablonlar) — herkes görebilsin (indirir), yazma personel
    match /applicationTemplates/{id} {
      allow read:  if true;
      allow write: if isStaff();
    }

    // ── Ortak koleksiyonlar — okuma: giriş yapmış herkes ───────────────
    // (öğrenci paneli program/duyuru/anket/QR okur; yazma personel)
    match /schedule/{id}          { allow read: if authed(); allow write: if isStaff(); }
    match /announcements/{id}     { allow read: if authed(); allow write: if isStaff(); }
    match /studentSurveys/{id}    { allow read: if authed(); allow write: if isStaff(); }
    match /studentStats/{id}      { allow read: if authed(); allow write: if isStaff(); }
    match /teacherLessonLogs/{id} { allow read: if authed(); allow write: if isStaff(); }
    match /qrSessions/{id}        { allow read: if authed(); allow write: if isStaff(); }
    match /config/{id}            { allow read: if authed(); allow write: if isStaff(); }
    match /admins/{id}            { allow read: if authed(); allow write: if isStaff(); }

    // ── Roller — personel her rolü yazabilir (kullanıcı oluşturma için);
    //    normal kullanıcı yalnızca KENDİ uid'ini yazar ve admin olamaz ──
    match /roles/{uid} {
      allow read:  if authed();
      allow write: if isStaff()
                   || (authed() && request.auth.uid == uid
                       && (!('role' in request.resource.data) || request.resource.data.role != 'admin'));
    }

    // ── Hem öğrenci hem personel okur/yazar ────────────────────────────
    //   attendance: öğrenci QR check-in + öğretmen yoklama kaydı
    //   messages / survey responses: öğrenci gönderir (istemci filtreli sorgular)
    //   devices: kullanıcı kendi cihaz kaydını yazar
    match /attendance/{id}             { allow read, write: if authed(); }
    match /messages/{id}               { allow read, write: if authed(); }
    match /surveyResponses/{id}        { allow read, write: if authed(); }
    match /studentSurveyResponses/{id} { allow read, write: if authed(); }
    match /devices/{id}                { allow read, write: if authed(); }
  }
}
