rules_version = '2';

// Firebase Storage — Akademîya Aram Tîgran
//
// photos/       : profil fotoğrafları — giriş yapmış kullanıcılar okur/yazar.
// applications/ : kayıt başvurusu belgeleri — site (girişsiz) YÜKLEYEBİLİR
//                 (yalnızca create; boyut ve tür sınırlı), silme/değiştirme
//                 yalnızca personel. Görüntüleme personel (indirme URL'leri
//                 token'lı olduğu için panel her durumda açar).
service firebase.storage {
  match /b/{bucket}/o {

    match /photos/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Haber medyası (basın paneli): site herkese açık gösterir → okuma serbest;
    // yükleme/silme yalnızca personel (basın kartı da @ogretmen.aat'dir).
    // Görsel ≤10MB, video ≤200MB.
    match /news/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
                   && request.auth.token.email.matches('.*@ogretmen[.]aat$')
                   && ((request.resource.contentType.matches('image/.*')
                        && request.resource.size < 10 * 1024 * 1024)
                       || (request.resource.contentType.matches('video/.*')
                        && request.resource.size < 200 * 1024 * 1024)
                       // altyazı dosyaları (.vtt)
                       || (request.resource.contentType.matches('text/.*')
                        && request.resource.size < 2 * 1024 * 1024));
      allow delete: if request.auth != null
                   && request.auth.token.email.matches('.*@ogretmen[.]aat$');
    }

    match /applications/{allPaths=**} {
      allow read:   if request.auth != null;
      // Girişsiz başvuru yüklemesi: en fazla 8MB, yalnızca görsel veya PDF.
      allow create: if request.resource.size < 8 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf');
      allow update, delete: if request.auth != null
                    && request.auth.token.email.matches('.*@ogretmen[.]aat$');
    }
  }
}
