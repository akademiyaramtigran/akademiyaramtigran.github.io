rules_version = '2';

// Firebase Storage — profil fotoğrafları
// Giriş yapmış kullanıcılar fotoğrafları görebilir/yükleyebilir.
// (Fotoğraflar hassas veri değil; yazma yetkisini personele daraltmak istersen
//  aşağıdaki write kuralını isStaff mantığıyla değiştirebilirsin.)
service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
